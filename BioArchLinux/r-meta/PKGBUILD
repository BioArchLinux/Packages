# Maintainer: Christos Longros <chris.longros@gmail.com>
_pkgname=meta
_pkgver=8.5-0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="General Package for Meta-Analysis"
arch=(any)
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-2.0-or-later')
depends=(
  r-cli
  r-compquadform
  r-dplyr
  r-ggplot2
  r-lme4
  r-magrittr
  r-metabook
  r-metafor
  r-purrr
  r-readr
  r-rlang
  r-scales
  r-stringr
  r-tibble
  r-xml2
)
optdepends=(
  r-biasedurn
  r-brglm2
  r-estmeansd
  r-gemtc
  r-ggpubr
  r-gridextra
  r-knitr
  r-metadat
  r-netmeta
  r-pimeta
  r-ragg
  r-rmarkdown
  r-robvis
  r-svglite
  r-writexl
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('9c4930d6b5130d035a8d9f83722be80c')
build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}
package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
