# Maintainer: shun2wang <shuonwang@gmail.com>

_pkgname=bgms
_pkgver=0.1.6.3
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=2
pkgdesc="Bayesian Analysis of Networks of Binary and/or Ordinal Variables"
arch=('x86_64')
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-2.0-or-later')
depends=(
  r-rcpp
  r-rdpack
  r-rcppparallel
  r-coda
  r-lifecycle
)
makedepends=(
  r-rcpparmadillo
  r-dqrng
  r-bh
)
optdepends=(
  r-covr
  r-knitr
  r-qgraph
  r-rmarkdown
  r-testthat
  r-ggplot2
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('8a075871cc702b9abca2260a056a64d0')
b2sums=('a8dc822b4832e3d4bf390e037cd008ad91ddea3dc7892545bf56d1852cae99403ea6afa65eea757a3a92414f1bb1bdbabfe674ad3f32dcf138806573d40d3e6a')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
