# Maintainer: Guoyi Zhang <guoyizhang at malacology dot net>

_pkgname=cli
_pkgver=3.6.6
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Helpers for Developing Command Line Interfaces"
arch=(x86_64)
url="https://cran.r-project.org/package=$_pkgname"
license=('MIT')
depends=(
  r
)
optdepends=(
  r-callr
  r-covr
  r-crayon
  r-digest
  r-glue
  r-htmltools
  r-htmlwidgets
  r-knitr
  r-processx
  r-ps
  r-rlang
  r-rmarkdown
  r-rprojroot
  r-rstudioapi
  r-testthat
  r-tibble
  r-whoami
  r-withr
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('eedc08ba864ae6cd640b05eff1a607ee')
b2sums=('d42aeed1b9a6d390ce3ca56583f1833dd6365c184383954739ee452a40cd09012e5c3dea7df6eb731d105026a084db06d2fa3acbe4e01db9171eb227cdd8039c')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"

  install -d "$pkgdir/usr/share/licenses/$pkgname"
  ln -s "/usr/lib/R/library/$_pkgname/LICENSE" "$pkgdir/usr/share/licenses/$pkgname"
}
