_pkgname=Biobase
_pkgver=2.72.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Base functions for Bioconductor"
arch=(x86_64)
url="https://bioconductor.org/packages/$_pkgname"
license=('Artistic-2.0')
depends=(
  r-biocgenerics
)
optdepends=(
  r-all
  r-biocstyle
  r-golubesets
  r-knitr
  r-limma
  r-runit
  r-tkwidgets
)
source=("https://bioconductor.org/packages/release/bioc/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('b3b23749597ddfccf0daeee65d1ec8f8')
b2sums=('90de9a7673bf0238cc6f58758e8acbc5b0021c3c19e6e742593ecf78e61bf42c4295b5acf9e72aae8132842dc44b0a02b85018fc13370c6300bd5ff596c92b9b')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
