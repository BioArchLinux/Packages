_pkgname=BiocGenerics
_pkgver=0.58.1
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="S4 generic functions used in Bioconductor"
arch=(any)
url="https://bioconductor.org/packages/$_pkgname"
license=('Artistic-2.0')
depends=(
  r-generics
)
optdepends=(
  r-affy
  r-affyplm
  r-annotate
  r-annotationdbi
  r-biobase
  r-delayedarray
  r-deseq2
  r-flowclust
  r-genomicranges
  r-hdf5array
  r-iranges
  r-msnbase
  r-pwalign
  r-rsamtools
  r-runit
  r-s4arrays
  r-s4vectors
  r-sparsearray
  r-multiassayexperiment
)
source=("https://bioconductor.org/packages/release/bioc/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('6aa4beaff2e84c0ff9d155a346a66eaa')
b2sums=('0725df9ad923b2d2b19bc1914f156546b61ba93d4f8d750491e94b76dcbd003835b16f81d12b959d2803258c605c932b20d40fd2d5899e7061784a5cc1b69981')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
