_pkgname=BiocGenerics
_pkgver=0.58.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="S4 generic functions used in Bioconductor"
arch=(any)
url="https://bioconductor.org/packages/$_pkgname"
license=('Artistic-2.0')
depends=(
  r-generics
)
optdepends=(
  r-affy
  r-affyplm
  r-annotate
  r-annotationdbi
  r-biobase
  r-delayedarray
  r-deseq2
  r-flowclust
  r-genomicranges
  r-hdf5array
  r-iranges
  r-msnbase
  r-pwalign
  r-rsamtools
  r-runit
  r-s4arrays
  r-s4vectors
  r-sparsearray
  r-multiassayexperiment
)
source=("https://bioconductor.org/packages/release/bioc/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('186ee7737091a575d838da959840d4b6')
b2sums=('c3fd270d0a23e0df503e5c2fcbe106dd30c7a3ee6b17bcf13c1827fcb8219ba4dab7a400af2d2ca1b06801c69db5422e83c4ccd3aaa9cd05bb7b17492158de61')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
