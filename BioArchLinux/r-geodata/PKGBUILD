# Maintainer: Guoyi <kuoi@bioarchlinux.org>

_pkgname=geodata
_pkgver=0.6-9
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//[:-]/.}
pkgrel=2
pkgdesc="Access Geographic Data"
arch=('any')
url="https://cran.r-project.org/package=${_pkgname}"
license=('GPL-3.0-or-later')
depends=(
  r-rappdirs
  r-terra
)
optdepends=(
  r-archive
  r-httr
  r-jsonlite
  r-r.utils
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('5ae770299bc3d4b83fdfc36e0a148056')
b2sums=('2a22796d17664baeb127d3e93acd35b669f2e2be325734529b6a45880dc605b16afd47d1eae7a5782a87483b3c4028af7f208824b18102afdc0cb714a885e9a9')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
