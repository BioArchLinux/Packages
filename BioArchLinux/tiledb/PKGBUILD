pkgname=tiledb
pkgver=2.24.2
pkgrel=1
pkgdesc="The Universal Storage Engine"
arch=(x86_64)
url="https://tiledb.com"
license=('MIT')
depends=(
  bzip2
  capnproto
  curl
  file
  fmt
  lz4
  openssl
  spdlog
  zlib
  zstd
)
makedepends=(
  git
  cmake
)
source=("git+https://github.com/TileDB-Inc/TileDB.git#tag=$pkgver"
        "system-libs.patch")
b2sums=('1587346c216a6265a262944581bb7618c91027e1872d76b694f871c04b5c208c69c726f4d24e8e3acb1b5144182f341a21d1ddf09128cfc4fc16ed558dde871f'
        '4c99b48a72cc921caa071d25f37380ea09878924d5b00c403bf00ca065e28a2d4e4304d85a2da4b6dc924532fa16f178fc8f3ec7c3b0c37f831f203b977c4117')

prepare() {
  cd TileDB

  sed -i 's/\${TILEDB_CAPNPROTO_VERSION} EXACT/\${TILEDB_CAPNPROTO_VERSION} REQUIRED/' cmake/Modules/FindCapnp_EP.cmake

  sed -i 's|find_file(libmagic_DICTIONARY magic.mgc|find_file(libmagic_DICTIONARY magic.mgc PATHS /usr/share/file/misc|' cmake/Modules/FindMagic_EP.cmake
  sed -i 's/if(NOT TILEDB_LIBMAGIC_EP_BUILT)/if(false)/' cmake/Modules/FindMagic_EP.cmake

  sed -i 's/DEPENDS "${MGC_GZIPPED_BIN_INPUT_FILE}"/DEPENDS "${MGC_GZIPPED_BIN_INPUT_FILE}" update-embedded-magic-data/' tiledb/CMakeLists.txt
  sed -i 's|< "${libmagic_DICTIONARY}"|< /usr/share/file/misc/magic.mgc|' tiledb/CMakeLists.txt
  sed -i 's/lz4::lz4/LZ4::lz4_shared/g' tiledb/CMakeLists.txt
  
  sed -i '/Re-generate tiledb-rest.capnp/!b;n;a \  add_dependencies(TILEDB_CORE_OBJECTS update-serialization)' tiledb/CMakeLists.txt

  sed -i 's/lz4::lz4/LZ4::lz4_shared/g' tiledb/sm/compressors/CMakeLists.txt

  sed -i '1i #include <algorithm>' tiledb/sm/filesystem/posix.cc
}

build() {
  TILEDB_DISABLE_AUTO_VCPKG=y \
      cmake -B build -S TileDB \
      -DCMAKE_BUILD_TYPE=None \
      -DCMAKE_INSTALL_PREFIX=/usr \
      -DTILEDB_SERIALIZATION=ON \
      -DTILEDB_TESTS=OFF \
      -DTILEDB_WEBP=OFF \
      -Wno-dev
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build/tiledb
  install -Dm644 -t "$pkgdir/usr/share/licenses/$pkgname" TileDB/LICENSE
}
