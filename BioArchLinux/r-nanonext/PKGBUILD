# Maintainer: Shun Wang <shuonwang at gmail dot com>

_pkgname=nanonext
_pkgver=1.10.1
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Lightweight Toolkit for Messaging, Concurrency and the Web"
arch=(x86_64)
url="https://cran.r-project.org/package=$_pkgname"
license=('MIT')
depends=(
  r
)
makedepends=(
  cmake
)
optdepends=(
  r-later
  r-litedown
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('4e2ce096d54edb3b54d519e4c6c8d904')
b2sums=('81ae75126882d521f8119e453c3cddb269641c24088b9ddc4acdbb7a5f31f2df61bab7dffd0050a697edd87d8a189fa7fc7bea585b58825a660bc04de7960b1a')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
