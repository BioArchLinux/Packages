_pkgname=nanonext
_pkgver=1.9.1
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Lightweight Toolkit for Messaging, Concurrency and the Web"
arch=(x86_64)
url="https://cran.r-project.org/package=$_pkgname"
license=('MIT')
depends=(
  r
)
makedepends=(
  cmake
)
optdepends=(
  r-later
  r-litedown
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('0dcbec265a87b5c0dac8e408ff593b81')
b2sums=('4cb13affa6da7c8fcc3c5a7d6b0c1a012cc441b90e4e177c79b6a4b8d76983e0ebe821872249bc9d6c54f0ebf52da5b65bc86a2a0e9fe3a4e4da6bbdb5cc4740')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
