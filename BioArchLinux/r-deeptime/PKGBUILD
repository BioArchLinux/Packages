_pkgname=deeptime
_pkgver=2.4.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//[:-]/.}
pkgrel=1
pkgdesc='Plotting Tools for Anyone Working in Deep Time'
arch=('any')
url="https://cran.r-project.org/package=${_pkgname}"
license=('GPL-3.0-or-later')
depends=(
  r-cli
  r-curl
  r-deeptimedata
  r-ggfittext
  r-ggforce
  r-ggh4x
  r-ggplot2
  r-gridextra
  r-grimport2
  r-gtable
  r-lifecycle
  r-rlang
  r-scales
)
optdepends=(
  r-ape
  r-disprity
  r-divdyn
  r-dplyr
  r-geomtextpath
  r-ggpattern
  r-ggrepel
  r-ggtree
  r-gsloid
  r-knitr
  r-palaeoverse
  r-paleotree
  r-phytools
  r-rmacrostrat
  r-rmarkdown
  r-svglite
  r-testthat
  r-tidytree
  r-vdiffr
  r-withr
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('1cc7b9332af67b0d694d149b9c7d8048')
b2sums=('7ce868469f51e659a0c99a45330cea0bdfb4f00dbd030f8409ea16953afe446fe3617633854fe02c52a79a91ba3dc23614e5ca1816a18ca6de36b3afe03d4806')


build() {
  R CMD INSTALL ${_pkgname}_${_pkgver}.tar.gz -l "${srcdir}"
}

package() {
  install -dm0755 "${pkgdir}/usr/lib/R/library"
  cp -a --no-preserve=ownership "${_pkgname}" "${pkgdir}/usr/lib/R/library"
}
