_pkgname=pkgload
_pkgver=1.5.3
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Simulate Package Installation and Attach"
arch=(any)
url="https://cran.r-project.org/package=$_pkgname"
license=('MIT')
depends=(
  r-cli
  r-desc
  r-fs
  r-glue
  r-lifecycle
  r-pkgbuild
  r-processx
  r-rlang
  r-rprojroot
)
optdepends=(
  r-bitops
  r-jsonlite
  r-mathjaxr
  r-pak
  r-rcpp
  r-remotes
  r-rstudioapi
  r-testthat
  r-usethis
  r-withr
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('9f38a3a0d87ea2d72d1d9e9b9bfd1106')
b2sums=('9a8e795fe145b2408d5178a435f8fc1681593d359384b0e0037f68b37753ffd2693a4fa67125a01bc8d79020e027378d94f336e670f46950771889a69abf9ae0')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
