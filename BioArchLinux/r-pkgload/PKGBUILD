_pkgname=pkgload
_pkgver=1.5.1
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Simulate Package Installation and Attach"
arch=(any)
url="https://cran.r-project.org/package=$_pkgname"
license=('MIT')
depends=(
  r-cli
  r-desc
  r-fs
  r-glue
  r-lifecycle
  r-pkgbuild
  r-processx
  r-rlang
  r-rprojroot
)
optdepends=(
  r-bitops
  r-jsonlite
  r-mathjaxr
  r-pak
  r-rcpp
  r-remotes
  r-rstudioapi
  r-testthat
  r-usethis
  r-withr
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('c8dfe6ef0466ff294122aeebee6b420d')
b2sums=('b30ac9269b06c133f4cd6c771c966c28c467c1b308d8836b0dd7f9226b30d37fd8c08e274f6d7e1d7898a467b38e8b2200fe9fff49b68b14c471db0f88bc9bd4')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
