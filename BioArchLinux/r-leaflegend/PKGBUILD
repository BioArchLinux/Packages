# Maintainer: Boris Shor <boris@bshor.com>

_pkgname=leaflegend
_pkgver=1.2.8
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc='Add Customized Legends to Leaflet Maps'
arch=(any)
url="https://leaflegend.delveds.com"
license=('MIT')
depends=(
  r-base64enc
  r-htmltools
  r-htmlwidgets
  r-leaflet
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('98553fa7a268a63eb5a80e4ca3cfd6bb')
b2sums=('854f0c3769544a7047239c038fa92e6695445e1616353e6b48735a4e8de04a0e528ae4c864f847a52a4d6d7687a274c67ad62872df70f19d47d11df0f37eb06c')

build() {
  R CMD INSTALL ${_pkgname}_${_pkgver}.tar.gz -l "${srcdir}"
}

package() {
  install -dm0755 "${pkgdir}/usr/lib/R/library"
  cp -a --no-preserve=ownership "${_pkgname}" "${pkgdir}/usr/lib/R/library"
  install -Dm644 "${_pkgname}/LICENSE" -t "${pkgdir}/usr/share/licenses/${pkgname}"
}
