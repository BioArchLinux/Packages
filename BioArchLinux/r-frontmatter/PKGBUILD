# Maintainer: Boris Shor <boris@bshor.com>

_pkgname=frontmatter
_pkgver=0.3.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc='Parse Front Matter from Documents'
arch=('x86_64')
url="https://github.com/posit-dev/frontmatter"
license=('MIT')
depends=(
  r-cpp11
  r-rlang
  r-tomledit
  r-yaml12
)
optdepends=(
  r-testthat
  r-withr
  r-yaml
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('521734d89d47790ca2de2e636760aa53')
b2sums=('b4697ee95ef5e4759e20e371593a8fcdb3bca50293872d39ab05f6c750376f5194b767a0f45a9ef26584e13d1d646d79ec5c8237bf165acd76092cc559db3296')

build() {
  mkdir build
  R CMD INSTALL -l build "${_pkgname}"
}

package() {
  install -dm0755 "${pkgdir}/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/${_pkgname}" "${pkgdir}/usr/lib/R/library"
  install -Dm644 "${_pkgname}/LICENSE" -t "${pkgdir}/usr/share/licenses/${pkgname}"
}
