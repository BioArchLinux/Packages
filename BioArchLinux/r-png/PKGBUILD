_pkgname=png
_pkgver=0.1-9
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Read and write PNG images"
arch=(x86_64)
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-2.0-only OR GPL-3.0-only')
depends=(
  libpng
  r
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('1410f91d9ac052c15c6eea3bc1c89672')
b2sums=('9d57ba8e6f87b524f3948aca800833493a2fefaf66346b7c3db849c0c59dabfc9e963546b64c5f481c13114294451387fede6150a63a476f2e18bb18a339973e')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
