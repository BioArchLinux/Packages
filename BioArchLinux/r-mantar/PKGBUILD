_pkgname=mantar
_pkgver=0.3.1
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Missingness Alleviation for Network Analysis"
arch=(any)
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-3.0-or-later')
depends=(
  r-rdpack
  r-mathjaxr
  r-glassofast
)
optdepends=(
  r-numderiv
  r-mice
  r-lavaan
  r-qgraph
  r-testthat
  r-knitr
  r-rmarkdown
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('f94433d59a2b1b089ece2fde687e1839')
b2sums=('dc48b670f48049282192b98d2294df22ae8de65025121460eb945999f5413b2bdb8e57e988720a47bfb50f649962ccc9b19836c5a4c4fc351d542705c087c4cf')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
