_pkgname=mantar
_pkgver=0.3.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Missingness Alleviation for Network Analysis"
arch=(any)
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-3.0-or-later')
depends=(
  r-rdpack
  r-mathjaxr
  r-glassofast
)
optdepends=(
  r-numderiv
  r-mice
  r-lavaan
  r-qgraph
  r-testthat
  r-knitr
  r-rmarkdown
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('c9fd768d26cf3bfe5206277143833210')
b2sums=('d19e36f1a7fca23f5a4668dbb289b0f569afd749fd20a865e1411eb02ec49eab30dfc74a72299b433fd6f0425afcbba3593b124a9888ba8cbf898d5fd52393ec')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
