_pkgname=GenomicRanges
_pkgver=1.64.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Representation and manipulation of genomic intervals"
arch=(any)
url="https://bioconductor.org/packages/$_pkgname"
license=('Artistic-2.0')
depends=(
  r-biocgenerics
  r-iranges
  r-s4vectors
  r-seqinfo
)
checkdepends=(
  r-runit
)
optdepends=(
  r-annotate
  r-annotationdbi
  r-annotationhub
  r-biobase
  r-biocstyle
  r-biostrings
  r-bsgenome
  r-bsgenome.hsapiens.ucsc.hg38
  r-bsgenome.mmusculus.ucsc.mm10
  r-bsgenome.scerevisiae.ucsc.saccer2
  r-deseq2
  r-dexseq
  r-digest
  r-edger
  r-genomeinfodb
  r-genomicalignments
  r-genomicfeatures
  r-gviz
  r-hgu95av2.db
  r-hgu95av2probe
  r-kegggraph
  r-keggrest
  r-knitr
  r-pasillabamsubset
  r-rmarkdown
  r-rnaseqdata.hnrnpc.bam.chr14
  r-rsamtools
  r-runit
  r-summarizedexperiment
  r-txdb.athaliana.biomart.plantsmart51
  r-txdb.dmelanogaster.ucsc.dm3.ensgene
  r-txdb.hsapiens.ucsc.hg38.knowngene
  r-txdb.mmusculus.ucsc.mm10.knowngene
  r-txdbmaker
  r-ucsc.utils
  r-variantannotation
)
source=("https://bioconductor.org/packages/release/bioc/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('16b687fa031d965176f4e50532fef0a1')
b2sums=('4425132f1134a93ab5d1181c200a59efcfcff12b5603009a5adf96d5135e5b9251274f20a0f3340de9a5d2120bb83af55f92b0cdbe7ffd97fe6b4ac10bfeebdb')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

check() {
  cd "$_pkgname/tests"
  R_LIBS="$srcdir/build" Rscript --vanilla run_unitTests.R
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
