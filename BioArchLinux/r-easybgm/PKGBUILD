# Maintainer: shun2wang <shuonwang@gmail.com>

_pkgname=easybgm
_pkgver=0.4.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Extracting and Visualizing Bayesian Graphical Models"
arch=(any)
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-2.0-or-later')
depends=(
  r-coda
  r-bdgraph
  r-bggm
  r-bgms
  r-dplyr
  r-ggplot2
  r-hdinterval
  r-igraph
  r-qgraph
)
optdepends=(
  r-testthat
  r-vdiffr
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('46b94149f3f67637118d933bb56840c5')
b2sums=('eebb7c3f3f6609630186eace39e9cc3233723099eeb5f1e4b348afda65e507878dc9468ab1103a8c128a61c9e855a5612fa2a6a08e4b92c0e565088f458f4928')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
