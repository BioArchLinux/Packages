_name=airr
pkgname=python-airr
pkgver=2.0.0
pkgrel=1
pkgdesc="AIRR Community Data Representation Standard reference library for antibody and TCR sequencing data."
arch=(any)
url="http://docs.airr-community.org"
license=(CC-BY-4.0)
depends=('python')
makedepends=('python-setuptools' 'python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_name::1}/${_name}/airr-2.0.0.tar.gz")
sha256sums=('3443d95e3088356ec9c5dc99f4879addd1ea1ee13fd43eb0a7ad9cf917838af3')

build() {
  cd "$srcdir/airr-2.0.0"
  python3 setup.py build
}

package() {
  cd "$srcdir/airr-2.0.0"
  python3 setup.py install --root=$pkgdir --optimize=1 --skip-build

  # make sure we don't install any world-writable or root-readable-only files
  # we shouldn't need to fix ownership as we extract tarballs as a non-root user
  # https://github.com/pypa/setuptools/issues/1328
  # https://github.com/LonamiWebs/Telethon/issues/1605
  chmod u=rwX,go=rX -R "$pkgdir"
  # make sure we don't install annoying files
  local _site_packages=$(python -c "import site; print(site.getsitepackages()[0])")
  rm -rf "$pkgdir/$_site_packages/tests/"
}

