_pkgname=vctrs
_pkgver=0.7.2
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Vector Helpers"
arch=(x86_64)
url="https://cran.r-project.org/package=$_pkgname"
license=('MIT')
depends=(
  r-cli
  r-glue
  r-lifecycle
  r-rlang
)
optdepends=(
  r-bit64
  r-covr
  r-crayon
  r-dplyr
  r-generics
  r-knitr
  r-pillar
  r-pkgdown
  r-rmarkdown
  r-testthat
  r-tibble
  r-waldo
  r-withr
  r-xml2
  r-zeallot
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('64c78fe32dad5f8692f8c775b22d402d')
b2sums=('2cf39bf08b2419de3774c6dcd821e94c365ba1fb9900ff22d9dc68807421d2492baf4152242836f67b4b77a5f665191bbf5e8c1cdc7dd6980d8396f186efffa0')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"

  install -d "$pkgdir/usr/share/licenses/$pkgname"
  ln -s "/usr/lib/R/library/$_pkgname/LICENSE" "$pkgdir/usr/share/licenses/$pkgname"
}
