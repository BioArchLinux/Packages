# Contributor: Shun Wang <shuonwang at gmail dot com>

_pkgname=mxsem
_pkgver=0.1.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Specify 'OpenMx' Models with a 'lavaan'-Style Syntax"
arch=(x86_64)
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-3.0-or-later')
depends=(
  r
  r-openmx
  r-rcpp
  r-dplyr
)
optdepends=(
  r-knitr
  r-rmarkdown
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('c4ab59c176f9ca29a611a3f2a2a8a044')
b2sums=('c4c867428cf8f924aeb1f722cbed12c71bb794871a53ec42e9aa6eed33029128dbd2026ac1bce0683ad15c13d9eed7ce78513568441e7fb2ea847cf4c7478d78')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"

  install -d "$pkgdir/usr/share/licenses/$pkgname"
  ln -s "/usr/lib/R/library/$_pkgname/LICENSE" "$pkgdir/usr/share/licenses/$pkgname"
}
