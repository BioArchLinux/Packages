_pkgname=getopt
_pkgver=1.21.1
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="C-Like 'getopt' Behavior"
arch=(any)
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-2.0-or-later')
depends=(
  r
)
optdepends=(
  r-testthat
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('93f58b28b2524783d7752d274dbc815b')
b2sums=('36bf0e345c6dec09c1ccaa24a12894e0b606b47b355aa1ad5f63554898efda1e4cf9ab69490301de1272b3fa7a6aac29b6a920d456ec5438bc6ab258302893f6')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
