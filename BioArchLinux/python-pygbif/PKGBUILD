_base=pygbif
pkgname=python-${_base}
pkgver=0.6.6
pkgrel=1
pkgdesc="Python client for the GBIF API"
arch=('any')
url="https://gbif.org"
license=('MIT')
depends=(
python-geomet
python-geojson-rewind
python-appdirs
python-sphinx-issues
python-requests-cache
python-shapely
python-urllib3
python-vcrpy
python-codecov
python-sphinx_rtd_theme
python-sphinx
		)
makedepends=(python-setuptools)

# options=(!emptydirs)
source=(https://pypi.org/packages/source/${_base::1}/${_base}/${_base}-${pkgver}.tar.gz)
sha512sums=('e31f436635622f0613fbd2e26b70000caed76858d6bf98107d346fc2193ddd44e9cb0ea5708ad6907312beaca5863467c48a914adf9720b12b7c64d4937df374')

build() {
  cd "${_base}-${pkgver}"
  python setup.py build
}

package() {
  cd "${_base}-${pkgver}"
  export PYTHONHASHSEED=0
  PYTHONPYCACHEPREFIX="${PWD}/.cache/cpython/" python setup.py install --prefix=/usr --root="${pkgdir}" --optimize=1 --skip-build
  install -Dm 644 LICENSE -t "${pkgdir}/usr/share/licenses/${pkgname}"
}
