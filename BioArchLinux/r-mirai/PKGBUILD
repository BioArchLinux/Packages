# Maintainer: Shun Wang <shuonwang at gmail dot com>

_pkgname=mirai
_pkgver=2.7.2
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Minimalist Async Evaluation Framework for R"
arch=('any')
url="https://cran.r-project.org/package=$_pkgname"
license=('MIT')
depends=(
  r-nanonext
)
optdepends=(
  r-cli
  r-litedown
  r-mori
  r-otel
  r-otelsdk
  r-secretbase
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('102c286631f6580ce76016a5620b601a')
b2sums=('283da8d254d816292ee4a0b5b964981029b0c04fc7b57b321889bfb011497cde06740b0c491c08139f5f38be2d0ca972dcac839d287392b37e78c19dae35bcd0')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
