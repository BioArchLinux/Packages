# Maintainer: Shun Wang <shuonwang at gmail dot com>

_pkgname=mirai
_pkgver=2.7.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Minimalist Async Evaluation Framework for R"
arch=('any')
url="https://cran.r-project.org/package=$_pkgname"
license=('MIT')
depends=(
  r-nanonext
)
optdepends=(
  r-cli
  r-later
  r-litedown
  r-mori
  r-otel
  r-otelsdk
  r-secretbase
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('4bcabd69fa218a5d7d5f7e62302e5d3a')
b2sums=('50985899aded1b6ef6db676baed0f6196b18a4aa8264a0af3b2b192949dab78e6979939789073b19a83a2f983c5bd9db434f56e14cd2b932c9ea832db826d2af')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
