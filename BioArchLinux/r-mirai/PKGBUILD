# Maintainer: Shun Wang <shuonwang at gmail dot com>

_pkgname=mirai
_pkgver=2.7.1
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Minimalist Async Evaluation Framework for R"
arch=('any')
url="https://cran.r-project.org/package=$_pkgname"
license=('MIT')
depends=(
  r-nanonext
)
optdepends=(
  r-cli
  r-later
  r-litedown
  r-mori
  r-otel
  r-otelsdk
  r-secretbase
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('542923640632cdba7d58355ee8cba2e6')
b2sums=('f360e32d7c6a12dfa10efbe3768da2abfc41526c1dcaabce78dade9b8b749f2f90b0e4a61460d90a59bbcbd03567611b44d1f641ab9e608911740b4ca9894fa0')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
