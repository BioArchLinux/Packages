_pkgname=tmap
_pkgver=4.4-1
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc='Thematic Maps'
arch=(any)
url="https://github.com/r-tmap/tmap"
license=('GPL-3.0-only')
depends=(
  r-base64enc
  r-classint
  r-cli
  r-cols4all
  r-data.table
  r-htmltools
  r-htmlwidgets
  r-leafem
  r-leafgl
  r-leaflegend
  r-leaflet
  r-leafsync
  r-maptiles
  r-rlang
  r-s2
  r-servr
  r-sf
  r-stars
  r-tmaptools
  r-units
)
optdepends=(
  r-av
  r-colorspace
  r-ggplot2
  r-gifski
  r-knitr
  r-lobstr
  r-rstudioapi
  r-rsvg
  r-shiny
  r-terra
  r-testthat
  r-transformr
  r-widgetframe
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('562a3af72e51d9e111fdabc797d05e90')
b2sums=('46da20104a681ff58069493547ee0f549dcfd3b8db62a331040a1b04873d18dd81d777d25c8af42c1e3eb414d4e22cc25ffc3f9bd00d6dcaf2aead253b67dfb4')

build() {
  R CMD INSTALL ${_pkgname}_${_pkgver}.tar.gz -l "${srcdir}"
}

package() {
  install -dm0755 "${pkgdir}/usr/lib/R/library"
  cp -a --no-preserve=ownership "${_pkgname}" "${pkgdir}/usr/lib/R/library"
}
