  r-lmertest
  r-logspline
  r-marginaleffects
  r-matchit
  r-mice
  r-mvtnorm
  r-nanoparquet
  r-ordinal
  r-palmerpenguins
  r-patchwork
  r-pbkrtest
  r-performance
  r-poorman
  r-pscl
  r-rcppeigen
  r-report
  r-rmarkdown
  r-rstanarm
  r-sandwich
  r-scales
  r-testthat
  r-tinyplot
