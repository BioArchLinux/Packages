_pkgname=mirt
_pkgver=1.46.1
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Multidimensional Item Response Theory"
arch=('x86_64')
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-3.0-or-later')
depends=(
  r-gparotation
  r-gridextra
  r-rcpp
  r-vegan
  r-deriv
  r-pbapply
  r-dcurver
  r-simdesign
  r-splines2
)
makedepends=(
  r-rcpparmadillo
)
optdepends=(
  r-latticeextra
  r-directlabels
  r-shiny
  r-knitr
  r-markdown
  r-rsolnp
  r-nloptr
  r-sirt
  r-plink
  r-mirai
  r-mirtcat
  r-testthat
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('76ca5556634112d1770f7f3f9370264d')
b2sums=('9266e0e40dd9a65c41eedfb78b2cf21daf10912e5b5601b3fd9bb9e85038f8ebb587baca762717b9e4f5fb7362908187fcc25a3990d1de69c8d8c405400f6289')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
