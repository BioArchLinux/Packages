_pkgname=ShortRead
_pkgver=1.70.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="FASTQ input and manipulation"
arch=(x86_64)
url="https://bioconductor.org/packages/$_pkgname"
license=('Artistic-2.0')
depends=(
  r-biobase
  r-biocgenerics
  r-biocparallel
  r-biostrings
  r-genomicalignments
  r-genomicranges
  r-hwriter
  r-iranges
  r-latticeextra
  r-pwalign
  r-rsamtools
  r-s4vectors
  r-seqinfo
  zlib
)
makedepends=(
  r-rhtslib
  r-xvector
)
optdepends=(
  r-biocstyle
  r-biomart
  r-genomicfeatures
  r-knitr
  r-runit
  r-yeastnagalakshmi
)
source=("https://bioconductor.org/packages/release/bioc/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('856d3095a8ffbcfcbd0ac30436d46b90')
b2sums=('4d5a3ee64f28cd198596017ed8fbcb04f815a65608a666ea194908a3ebfcbc2c06cb437cba92fc2a5d423f5ff0be31be29b896b841136802239218f9bd69217c')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
