_pkgname=SimDesign
_pkgver=2.25
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Structure for Organizing Monte Carlo Simulation Designs"
arch=('any')
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-2.0-or-later')
depends=(
  r-clipr
  r-e1071
  r-testthat
  r-parallelly
  r-dplyr
  r-sessioninfo
  r-beepr
  r-pbapply
  r-future
  r-future.apply
  r-progressr
  r-r.utils
  r-mirai
  r-qs2
)
optdepends=(
  r-knitr
  r-ggplot2
  r-tidyr
  r-purrr
  r-shiny
  r-copula
  r-extradistr
  r-renv
  r-cli
  r-job
  r-future.batchtools
  r-frf2
  r-rmarkdown
  r-httr
  r-rpushbullet
  r-snow
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('1b77c49aef705df1968c8fdc5ce5bb13')
b2sums=('ce6aab3e3dee3ace0fad97ecb6f86bdd5f08967b0ea77b0ee07cb285922bb7728be62b995592b69b60a731b5c018ae632ab02fd94b8ad1d5586589fbed25975a')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
