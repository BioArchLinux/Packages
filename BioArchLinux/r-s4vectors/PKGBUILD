_pkgname=S4Vectors
_pkgver=0.50.1
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Foundation of vector-like and list-like containers in Bioconductor"
arch=(x86_64)
url="https://bioconductor.org/packages/$_pkgname"
license=('Artistic-2.0')
depends=(
  r-biocgenerics
)
optdepends=(
  r-biocstyle
  r-data.table
  r-delayedarray
  r-genomicranges
  r-graph
  r-iranges
  r-knitr
  r-runit
  r-shortread
  r-summarizedexperiment
)
source=("https://bioconductor.org/packages/release/bioc/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('b65ef1a398c688677648a1595b524caf')
b2sums=('4077347bc09ce0cda5323d390b10948efdb3f6dbc3bb359bc293df56ae20ce2fc8a1b71ed2d3cc1986f319fdfba1ae4ff2687e9fbf30279b4a4ed2af8a7b34f3')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
