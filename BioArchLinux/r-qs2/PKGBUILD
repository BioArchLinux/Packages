_pkgname=qs2
_pkgver=0.2.2
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Efficient Serialization of R Objects"
arch=('x86_64')
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-3.0-only')
depends=(
  r-rcpp
  r-rcppparallel
  r-stringfish
)
makedepends=(
)
optdepends=(
  r-data.table
  r-dplyr
  r-knitr
  r-rmarkdown
  r-stringi
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('ee82f2633108f37570128a214dcc3650')
b2sums=('e8d9c6bad155539fefb76b4c3df7f2249abb3f779e96946bebbe7d3ebd73e944c95eb508e1479bf394595b5efb605d64200f6ab23399737550db71f681ead44d')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
