_pkgname=BiocParallel
_pkgver=1.46.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Bioconductor facilities for parallel evaluation"
arch=(x86_64)
url="https://bioconductor.org/packages/$_pkgname"
license=('GPL-2.0-or-later')
depends=(
  r-futile.logger
  r-snow
)
makedepends=(
  r-bh
  r-cpp11
)
optdepends=(
  r-batchtools
  r-bbmisc
  r-biocgenerics
  r-biocstyle
  r-data.table
  r-doparallel
  r-foreach
  r-genomicalignments
  r-genomicranges
  r-knitr
  r-rnaseqdata.hnrnpc.bam.chr14
  r-rsamtools
  r-runit
  r-shortread
  r-txdb.hsapiens.ucsc.hg19.knowngene
  r-variantannotation
)
source=("https://bioconductor.org/packages/release/bioc/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('6b273932d1944fa81ae0e2cf8a2cc471')
b2sums=('06df1a3c79ad2e43ad769e8f3a9680770526658b04144d5f133a1ffc785b916c422d12dc5793b9662c117fc01c5a6d9bd7eec81448d667af0b58f111b0c47f6c')

prepare() {
  cd "$_pkgname"

  # BiocParallel contains selected Boost 1.87 Interprocess
  # headers. Mixing these with Boost 1.90 headers from BH causes ABI/API
  # incompatible template definitions, including construct_n().
  # Use only the internally consistent Boost headers supplied by BH.

  local file

  while IFS= read -r file; do
    sed -i \
      -e 's@boost_patch_1_87/interprocess/@boost/interprocess/@g' \
      -e 's@-I\./boost_patch_1_87@@g' \
      -e 's@-Iboost_patch_1_87@@g' \
      -e 's@-Isrc/boost_patch_1_87@@g' \
      "$file"
  done < <(
    grep -RIl 'boost_patch_1_87' \
      configure configure.ac src 2>/dev/null || true
  )

  rm -rf src/boost_patch_1_87

  if grep -RIn 'boost_patch_1_87' \
      configure configure.ac src 2>/dev/null; then
    error "References to boost_patch_1_87 remain after patching"
    return 1
  fi
}

build() {
  mkdir -p build
  R CMD INSTALL --preclean -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
