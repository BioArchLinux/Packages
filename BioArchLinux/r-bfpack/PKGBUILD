_pkgname=BFpack
_pkgver=1.6.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=2
pkgdesc="Flexible Bayes Factor Testing of Scientific Expectations"
arch=('x86_64')
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-3.0-or-later')
depends=(
  r-bain
  r-mvtnorm
  r-pracma
  r-lme4
  r-ergm
  r-bergm
  r-sandwich
  r-qrm
  r-coda
  r-metabma
  r-berryfunctions
)
makedepends=(
  gcc-fortran
)
optdepends=(
  r-testthat
  r-polycor
  r-pscl
  r-metafor
  r-knitr
  r-rmarkdown
  r-lmtest
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('bd545c969a49167f5634ea41739f0a55')
b2sums=('737f6ef7f21ce0f155995a10755feed0e8814fcfeb4a0416965c1e64c7318816eeb9790b8fda5711dfe96211b110f16551d2d7c915393a6b5d7bb51146fb1120')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
