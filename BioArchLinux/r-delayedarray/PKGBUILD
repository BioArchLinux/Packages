_pkgname=DelayedArray
_pkgver=0.38.2
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="A unified framework for working transparently with on-disk and in-memory array-like datasets"
arch=(any)
url="https://bioconductor.org/packages/$_pkgname"
license=('Artistic-2.0')
depends=(
  r-biocgenerics
  r-iranges
  r-matrixgenerics
  r-s4arrays
  r-s4vectors
  r-sparsearray
)
optdepends=(
  r-airway
  r-biocparallel
  r-biocstyle
  r-delayedmatrixstats
  r-genefilter
  r-hdf5array
  r-knitr
  r-lobstr
  r-rmarkdown
  r-runit
  r-summarizedexperiment
  r-zarrarray
)
source=("https://bioconductor.org/packages/release/bioc/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('01223fbdc2a77a81a05b2683f1bd317f')
b2sums=('668a86df7350c7460bd6062f89479876e47af42e0bd730e6ae905f97019cda62bdce76a8841f9e3133d27a011b785f4a6c6b94ba695f3656789b78879d38927a')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
