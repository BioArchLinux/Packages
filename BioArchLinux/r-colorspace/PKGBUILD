_pkgname=colorspace
_pkgver=2.1-3
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="A Toolbox for Manipulating and Assessing Colors and Palettes"
arch=(x86_64)
url="https://cran.r-project.org/package=$_pkgname"
license=('BSD-3-Clause')
depends=(
  r
)
optdepends=(
  r-dplyr
  r-ggplot2
  r-jpeg
  r-kernlab
  r-knitr
  r-mvtnorm
  r-png
  r-rcartocolor
  r-rcolorbrewer
  r-rmarkdown
  r-scales
  r-scico
  r-shiny
  r-shinyjs
  r-vcd
  r-viridis
  r-wesanderson
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('44beb9a1ff66bf35b44663b4fa7ef2ae')
b2sums=('b582e11a8538ba8f2ce735fd971f2df94d88ac5e81fbbd227af401b84ba4fa1bb873662afca94516ad199e97dc2276b53ec7ead2f6b11ae23a69421bc0dbc859')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"

  install -d "$pkgdir/usr/share/licenses/$pkgname"
  ln -s "/usr/lib/R/library/$_pkgname/LICENSE" "$pkgdir/usr/share/licenses/$pkgname"
}
