_pkgname=showtext
_pkgver=0.9-8
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=2
pkgdesc="Using Fonts More Easily in R Graphs"
arch=(x86_64)
url="https://cran.r-project.org/package=$_pkgname"
license=(Apache)
depends=(
  freetype2
  r-showtextdb
  r-sysfonts
)
optdepends=(
  r-curl
  r-jsonlite
  r-knitr
  r-prettydoc
  r-rmarkdown
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('c3b07977ad22967335bfbc87b74e6376')
b2sums=('13e59fdea550a997c1b93b261c24e546ebb551373cbeb735862f052eb1afda2e88bf3bc4dc41e27ba87ddadbf99d30ad83c6cfc7efcd87f090f824dd3f0b5315')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
