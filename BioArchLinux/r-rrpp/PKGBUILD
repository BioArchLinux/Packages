# Maintainer: Guoyi <kuoi@malacology.net>

_pkgname=RRPP
_pkgver=2.2.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc='Linear Model Evaluation with Randomized Residuals in a Permutation Procedure'
arch=('any')
url="https://cran.r-project.org/package=${_pkgname}"
license=('GPL-3.0-or-later')
depends=(
  r-ape
  r-ggplot2
  r-lme4
)
optdepends=(
  r-dplyr
  r-knitr
  r-rmarkdown
  r-testthat
  r-tibble
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('d991b2cdd32e85efe77896af1ed8592c')
b2sums=('7575345e363d1a1c8beaefd42111df038112b5f08c4f8aeafb99428025ac58b14e631a06fe2e29f35b2ccd154f166f770ef52d3b956cac375882afbacf6862d3')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
