# Maintainer: Guoyi Zhang <guoyizhang at malacology dot net>

_pkgname=rlang
_pkgver=1.3.0
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Functions for Base Types and Core R and 'Tidyverse' Features"
arch=(x86_64)
url="https://cran.r-project.org/package=$_pkgname"
license=('MIT')
depends=(
  r
)
optdepends=(
  r-cli
  r-covr
  r-crayon
  r-desc
  r-fs
  r-glue
  r-knitr
  r-magrittr
  r-pillar
  r-pkgload
  r-rmarkdown
  r-testthat
  r-tibble
  r-usethis
  r-vctrs
  r-withr
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('b52c165e43f4d7fe5cfa15c5c9467ff4')
b2sums=('3bc6cba32f08de9789ddc6a9a3f095c5dfab0e2d93496fdc4438626f732458a373012869105e708291a8c393706c6dca5503a32d6b6570b2c6231bcf3000503c')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"

  install -d "$pkgdir/usr/share/licenses/$pkgname"
  ln -s "/usr/lib/R/library/$_pkgname/LICENSE" "$pkgdir/usr/share/licenses/$pkgname"
}
