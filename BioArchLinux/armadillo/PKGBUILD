# Contributor: Mick Elliot <m.g.elliot@rug.nl>

pkgname=armadillo
sfname=arma
pkgver=15.2.6
pkgrel=1
pkgdesc="C++ library for linear algebra & scientific computing"
arch=('x86_64')
url="http://${sfname}.sourceforge.net/"
license=('Apache-2.0')
depends=(openblas lapack)
makedepends=(cmake)
source=("http://sourceforge.net/projects/${sfname}/files/${pkgname}-${pkgver}.tar.xz")

sha256sums=('97cb8ef708541f632e861d005a462dd0367240f81ff96f8e63ebbdd75c8ce55f')

build() {
  cd "${pkgname}-${pkgver}"
  cmake . -DCMAKE_INSTALL_PREFIX="/usr"
  make
}

package() {
  cd "${pkgname}-${pkgver}"
  make DESTDIR=${pkgdir} install
  install -Dm644 LICENSE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
