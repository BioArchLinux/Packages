# Maintainer: Boris Shor <boris@bshor.com>

_pkgname=cols4all
_pkgver=0.10
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=2
pkgdesc='Colors for all'
arch=(any)
url="https://cols4all.github.io/cols4all-R/"
license=('GPL-3.0-only')
depends=(
  r-abind
  r-colorspace
  r-png
  r-spacesxyz
  r-stringdist
)
optdepends=(
  r-bibtex
  r-bookdown
  r-colorblindcheck
  r-ggplot2
  r-kableextra
  r-knitr
  r-plotly
  r-rmarkdown
  r-scales
  r-shiny
  r-shinyjs
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('65d55d7be5728e5f51b5ec595fe73e5d')
b2sums=('e9973cdcedbe07b7cc5d8ca7e645456092b5c7e1d915716c47834878db301374106353ce6d3a73c57b37ce6c871ef576974f72726c545fa22533b74353a5fc86')

build() {
  R CMD INSTALL ${_pkgname}_${_pkgver}.tar.gz -l "${srcdir}"
}

package() {
  install -dm0755 "${pkgdir}/usr/lib/R/library"
  cp -a --no-preserve=ownership "${_pkgname}" "${pkgdir}/usr/lib/R/library"
}
